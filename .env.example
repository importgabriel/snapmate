# ===========================================================================
#  TripSnap — environment variable reference
#  Copy this file to .env.local and fill in every value before running the
#  app.  Never commit .env.local to source control.
# ===========================================================================

# ---------------------------------------------------------------------------
#  Supabase — https://supabase.com/dashboard/project/<ref>/settings/api
# ---------------------------------------------------------------------------

# Public project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key — only gives access that your RLS policies allow
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# Service role key — NEVER expose this to the browser.
# Used only in server-side API routes that need to bypass RLS
# (e.g. background face-tagging jobs, admin operations).
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-secret-key>

# ---------------------------------------------------------------------------
#  AWS — https://console.aws.amazon.com/iam
#  The IAM user / role must have:
#    - rekognition:IndexFaces
#    - rekognition:SearchFacesByImage
#    - rekognition:DeleteFaces
#    - rekognition:CreateCollection   (first-time setup)
# ---------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>

# Region where your Rekognition collection lives (e.g. us-east-1)
AWS_REGION=us-east-1

# The Rekognition Face Collection ID created for this project.
# Create one with: aws rekognition create-collection --collection-id tripsnap-faces
AWS_REKOGNITION_COLLECTION_ID=tripsnap-faces

# ---------------------------------------------------------------------------
#  App — general
# ---------------------------------------------------------------------------

# Full public URL of the deployed app (used for invite link generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
